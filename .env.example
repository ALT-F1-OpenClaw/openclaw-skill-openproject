# OpenProject Skill Configuration
# Copy to .env and fill in your values

# OpenProject instance URL (cloud or self-hosted)
# e.g. https://projects.xflowdata.com or https://mycompany.openproject.com
OP_HOST=

# API token from My Account → Access Tokens
OP_API_TOKEN=

# Optional: default project identifier (e.g. my-project)
OP_DEFAULT_PROJECT=

# Optional: max results per query (default 50)
OP_MAX_RESULTS=50
